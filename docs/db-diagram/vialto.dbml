Table cargas_combustible as "[IMP-COMB] cargas_combustible" {
  id String [pk]
  tenantId String [not null, ref: > tenants.clerkOrgId]
  vehiculoId String [ref: > vehiculos.id]
  choferId String [ref: > choferes.id]
  estacion String [not null]
  litros Float [not null]
  precioPorLitro Float [default: 0]
  importe Float [not null]
  km Int [not null]
  formaPago String
  fecha DateTime [not null]
  createdAt DateTime [default: `now()`]
  createdBy String [not null]
  fotoTacometro String [note: 'Cloudinary']
  fotoTicket String [note: 'Cloudinary']
  sospechoso Boolean [default: false]
  motivoSospecha String
  litrosOriginal Float
  kmOriginal Int

  Indexes {
    tenantId
    (tenantId, vehiculoId)
    (tenantId, choferId)
    (tenantId, fecha)
    (tenantId, createdBy)
    (tenantId, sospechoso)
  }
}

