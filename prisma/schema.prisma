generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")           // pooled (PgBouncer) — para runtime
  directUrl = env("DATABASE_URL_UNPOOLED")  // directa (sin pooler) — solo para migraciones
}

// ═══════════════════════════════════════════════════════════════════════════
// Enums
// ═══════════════════════════════════════════════════════════════════════════

enum BillingStatus {
  trial
  active
  suspended
  expired
}

enum TipoVehiculo {
  tractor
  semirremolque
  camion
  utilitario
  otro
}

enum EstadoViaje {
  pendiente
  en_curso
  finalizado_sin_facturar
  facturado_sin_cobrar
  cobrado
  cancelado
}

enum Moneda {
  ARS
  USD
}

enum TipoFactura {
  cliente
  transportista_externo
}

enum EstadoFactura {
  pendiente
  cobrada
  vencida
}

enum FormaPago {
  transferencia
  cheque
  efectivo
}

enum TipoMovimientoCuentaCorriente {
  cargo
  pago
}

enum OrigenMovimientoCuentaCorriente {
  manual
  viaje
}

enum UnidadProducto {
  kg
  unidad
  palet
  rollo
  otro
}

enum TipoMovimientoStock {
  ingreso
  egreso
  division
}

enum TipoIntervencion {
  service
  aceite
  filtro
  cubiertas
  otro
}

enum EstadoRemito {
  emitido
  firmado
  facturado
}

enum EstadoImportLog {
  completado
  con_errores
  fallido
}

// ═══════════════════════════════════════════════════════════════════════════
// Tenant — una fila por organización Clerk (tenantId en tablas = clerkOrgId)
// ═══════════════════════════════════════════════════════════════════════════

model Tenant {
  id               String   @id @default(cuid())
  clerkOrgId       String   @unique
  name             String
  cuit             String?  @unique
  modules          String[] @default([])
  maxUsers         Int      @default(10)
  billingStatus    BillingStatus   @default(trial)
  billingRenewsAt  DateTime?
  whiteLabelDomain String?
  createdAt        DateTime @default(now())

  clientes                Cliente[]
  transportistas          Transportista[]
  choferes                Chofer[]
  vehiculos               Vehiculo[]
  viajes                  Viaje[]
  facturas                Factura[]
  pagos                   Pago[]
  movimientosCc           MovimientoCuentaCorriente[]
  productos               Producto[]
  movimientosStock        MovimientoStock[]
  cargasCombustible       CargaCombustible[]
  intervenciones          Intervencion[]
  remitos                 Remito[]
  importTemplates         ImportTemplate[]
  importLogs              ImportLog[]
  importSessions          ImportSession[]

  @@map("tenants")
}

// ═══════════════════════════════════════════════════════════════════════════
// Core (siempre presentes)
// ═══════════════════════════════════════════════════════════════════════════

model Cliente {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  nombre    String
  cuit      String?
  email     String?
  telefono  String?
  direccion String?
  pais      String?
  createdAt DateTime @default(now())

  viajes           Viaje[]
  facturas         Factura[]
  movimientosCc    MovimientoCuentaCorriente[]
  movimientosStock MovimientoStock[]
  remitos          Remito[]

  @@index([tenantId])
  @@map("clientes")
}

model Transportista {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  nombre    String
  cuit      String?
  email     String?
  telefono  String?
  createdAt DateTime @default(now())

  choferes  Chofer[]
  vehiculos Vehiculo[]
  viajes    Viaje[]
  facturas  Factura[]

  @@index([tenantId])
  @@map("transportistas")
}

model Chofer {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  nombre          String
  dni             String?
  licencia        String?
  licenciaVence   DateTime?
  telefono        String?
  transportistaId String?
  transportista   Transportista? @relation(fields: [transportistaId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  viajes              Viaje[]
  cargasCombustible   CargaCombustible[]
  remitos             Remito[]

  @@index([tenantId])
  @@map("choferes")
}

model Vehiculo {
  id                 String    @id @default(cuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  patente            String
  tipo               TipoVehiculo
  marca              String?
  modelo             String?
  anio               Int?
  kmActual           Int       @default(0)
  nroChasis          String?
  poliza             String?
  vencimientoPoliza  DateTime?
  tara               Float?
  precinto           String?
  transportistaId    String?
  transportista      Transportista? @relation(fields: [transportistaId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())

  vehiculosViaje    ViajeVehiculo[]
  cargasCombustible CargaCombustible[]
  intervenciones    Intervencion[]
  remitos           Remito[]

  @@unique([tenantId, patente])
  @@index([tenantId])
  @@map("vehiculos")
}

model ViajeVehiculo {
  id         String   @id @default(cuid())
  tenantId   String
  viajeId    String
  viaje      Viaje    @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  vehiculoId String
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  orden      Int      @default(0)

  @@unique([viajeId, vehiculoId])
  @@index([tenantId])
  @@index([viajeId])
  @@index([vehiculoId])
  @@map("viajes_vehiculos")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: viajes
// ═══════════════════════════════════════════════════════════════════════════

model Viaje {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  numero           String
  estado           EstadoViaje @default(pendiente)
  clienteId        String
  cliente          Cliente   @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  transportistaId  String?
  transportista    Transportista? @relation(fields: [transportistaId], references: [id], onDelete: SetNull)
  choferId         String?
  chofer           Chofer?   @relation(fields: [choferId], references: [id], onDelete: SetNull)
  vehiculosViaje   ViajeVehiculo[]
  origen           String?
  destino          String?
  fechaCarga       DateTime?
  fechaDescarga    DateTime?
  detalleCarga     String?
  kmRecorridos     Int?
  litrosConsumidos Float?
  monto            Float?
  /** ARS | USD */
  monedaMonto      Moneda    @default(ARS)
  precioTransportistaExterno Float?
  /** ARS | USD */
  monedaPrecioTransportistaExterno Moneda @default(ARS)
  observaciones    String?
  fechaFinalizado  DateTime?
  createdAt        DateTime  @default(now())
  createdBy        String

  facturaId  String?
  factura    Factura? @relation(fields: [facturaId], references: [id], onDelete: SetNull)
  movimientosCuentaCorriente MovimientoCuentaCorriente[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, clienteId])
  @@index([tenantId, transportistaId])
  @@index([tenantId, fechaCarga])
  @@index([tenantId, fechaDescarga])
  @@index([tenantId, fechaFinalizado])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, estado, fechaDescarga])
  @@map("viajes")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: facturación
// ═══════════════════════════════════════════════════════════════════════════

model Factura {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  numero           String
  tipo             TipoFactura
  clienteId        String?
  cliente          Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  transportistaId  String?
  transportista    Transportista? @relation(fields: [transportistaId], references: [id], onDelete: SetNull)
  viajes           Viaje[]
  importe          Float
  fechaEmision     DateTime
  fechaVencimiento DateTime?
  estado           EstadoFactura @default(pendiente)
  diferencia       Float?
  createdAt        DateTime  @default(now())
  pagos            Pago[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([tenantId, clienteId])
  @@index([tenantId, transportistaId])
  @@index([tenantId, estado])
  @@index([tenantId, fechaEmision])
  @@map("facturas")
}

model Pago {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  facturaId String
  factura   Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  importe   Float
  fecha     DateTime
  formaPago FormaPago?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, facturaId])
  @@map("pagos")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: cuenta corriente
// ═══════════════════════════════════════════════════════════════════════════

model MovimientoCuentaCorriente {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  viajeId    String?
  viaje      Viaje?  @relation(fields: [viajeId], references: [id], onDelete: SetNull)
  tipo       TipoMovimientoCuentaCorriente
  origen     OrigenMovimientoCuentaCorriente @default(manual)
  concepto   String
  importe    Float
  fecha      DateTime
  referencia String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, clienteId])
  @@index([tenantId, clienteId, tipo])
  @@index([tenantId, fecha])
  @@index([tenantId, origen])
  @@index([tenantId, viajeId])
  @@unique([tenantId, viajeId])
  @@map("movimientos_cuenta_corriente")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: stock
// ═══════════════════════════════════════════════════════════════════════════

model Producto {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  nombre    String
  unidad    UnidadProducto
  createdAt DateTime @default(now())

  movimientos MovimientoStock[]

  @@index([tenantId])
  @@map("productos")
}

model MovimientoStock {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  tipo       TipoMovimientoStock
  cantidad   Float
  pesoKg     Float?
  remitoId   String?
  remito     Remito?  @relation(fields: [remitoId], references: [id], onDelete: SetNull)
  fecha      DateTime
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, productoId])
  @@index([tenantId, clienteId])
  @@index([tenantId, remitoId])
  @@index([tenantId, fecha])
  @@map("movimientos_stock")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: combustible
// ═══════════════════════════════════════════════════════════════════════════

model CargaCombustible {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  vehiculoId String
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  choferId   String?
  chofer     Chofer?  @relation(fields: [choferId], references: [id], onDelete: SetNull)
  estacion   String
  litros     Float
  importe    Float
  km         Int
  formaPago  FormaPago?
  fecha      DateTime
  createdAt  DateTime @default(now())
  createdBy  String

  @@index([tenantId])
  @@index([tenantId, vehiculoId])
  @@index([tenantId, choferId])
  @@index([tenantId, fecha])
  @@index([tenantId, createdBy])
  @@map("cargas_combustible")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: mantenimiento (PostgreSQL; checklist diario en Firestore según doc)
// ═══════════════════════════════════════════════════════════════════════════

model Intervencion {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  vehiculoId  String
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  tipo        TipoIntervencion
  descripcion String?
  km          Int?
  proximoKm   Int?
  fecha       DateTime
  createdAt   DateTime @default(now())
  createdBy   String

  @@index([tenantId])
  @@index([tenantId, vehiculoId])
  @@index([tenantId, fecha])
  @@map("intervenciones")
}
// ═══════════════════════════════════════════════════════════════════════════

model Remito {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  numero      String
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  choferId    String?
  chofer      Chofer?  @relation(fields: [choferId], references: [id], onDelete: SetNull)
  vehiculoId  String?
  vehiculo    Vehiculo? @relation(fields: [vehiculoId], references: [id], onDelete: SetNull)
  descripcion String
  fecha       DateTime
  firmaUrl    String?
  estado      EstadoRemito @default(emitido)
  createdAt   DateTime @default(now())
  movimientosStock MovimientoStock[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([tenantId, clienteId])
  @@index([tenantId, estado])
  @@index([tenantId, fecha])
  @@map("remitos")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: importaciones
// ═══════════════════════════════════════════════════════════════════════════

model ImportTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  modulo    String   // viajes | clientes | choferes | vehiculos | stock | etc.
  nombre    String
  config    Json     // TemplateConfig: sheet, headerRow, columns[]
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs     ImportLog[]
  sessions ImportSession[]

  @@unique([tenantId, modulo])
  @@index([tenantId])
  @@map("import_templates")
}

model ImportSession {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  templateId    String
  template      ImportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  nombreArchivo String
  filasValidas  Json           // ValidatedRow[] — listas para insertar
  errores       Json           // RowError[]
  totalFilas    Int
  expiresAt     DateTime
  createdAt     DateTime       @default(now())

  @@index([tenantId])
  @@map("import_sessions")
}

model ImportLog {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  templateId    String?
  template      ImportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  modulo        String
  nombreArchivo String
  estado        EstadoImportLog @default(completado)
  totalFilas    Int
  exitosas      Int             @default(0)
  errores       Int             @default(0)
  detalles      Json            // [{ fila: 2, estado: "ok", id: "..." }, { fila: 3, estado: "error", mensaje: "..." }]
  createdAt     DateTime        @default(now())
  createdBy     String

  @@index([tenantId])
  @@index([tenantId, modulo])
  @@map("import_logs")
}
