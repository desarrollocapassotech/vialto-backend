Table remitos as "[IMP-REMITOS] remitos" {
  id String [pk]
  tenantId String [not null, ref: > tenants.clerkOrgId]
  numero String [not null]
  clienteId String [not null, ref: > clientes.id]
  choferId String [ref: > choferes.id]
  vehiculoId String [ref: > vehiculos.id]
  descripcion String [not null]
  fecha DateTime [not null]
  firmaUrl String [note: 'Cloudinary — firma digital']
  estado String [default: 'emitido', note: 'emitido|firmado|facturado']
  createdAt DateTime [default: `now()`]

  Indexes {
    (tenantId, numero) [unique]
    tenantId
    (tenantId, clienteId)
    (tenantId, estado)
    (tenantId, fecha)
  }
}

