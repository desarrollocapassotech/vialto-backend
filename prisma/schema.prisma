generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")           // pooled (PgBouncer) — para runtime
  directUrl = env("DATABASE_URL_UNPOOLED")  // directa (sin pooler) — solo para migraciones
}

// ═══════════════════════════════════════════════════════════════════════════
// Tenant — una fila por organización Clerk (tenantId en tablas = clerkOrgId)
// ═══════════════════════════════════════════════════════════════════════════

model Tenant {
  id               String   @id @default(cuid())
  clerkOrgId       String   @unique
  name             String
  idFiscal         String?  @unique
  modules          String[] @default([])
  maxUsers         Int      @default(10)
  billingStatus    String   @default("trial") // trial | active | suspended | expired
  billingRenewsAt  DateTime?
  whiteLabelDomain String?
  createdAt        DateTime @default(now())

  clientes                Cliente[]
  transportistas          Transportista[]
  choferes                Chofer[]
  vehiculos               Vehiculo[]
  viajes                  Viaje[]
  facturas                Factura[]
  pagos                   Pago[]
  movimientosCc           MovimientoCuentaCorriente[]
  productos               Producto[]
  movimientosStock        MovimientoStock[]
  stockItems              StockItem[]
  cargasCombustible       CargaCombustible[]
  intervenciones          Intervencion[]
  remitos                 Remito[]
  importTemplates         ImportTemplate[]
  importLogs              ImportLog[]
  importSessions          ImportSession[]
  stockRemitoSecuencias   StockRemitoSecuencia[]
  stockEgresoRemitoConfig StockEgresoRemitoConfig?
  arcaConfig              ArcaConfig?
  liquidaciones           Liquidacion[]
  arcaLogs                ArcaLog[]

  @@map("tenants")
}

// ═══════════════════════════════════════════════════════════════════════════
// Core (siempre presentes)
// ═══════════════════════════════════════════════════════════════════════════

model Cliente {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  nombre       String
  idFiscal     String?
  email        String?
  telefono     String?
  direccion    String?
  pais                String?
  condicionIva        Int?     // AFIP: 1=IVA RI, 4=IVA Exento, 5=Consumidor Final, 6=Monotributo
  condicionTributaria String?  // condición tributaria genérica (para países no AR)
  createdAt           DateTime @default(now())

  viajes           Viaje[]
  facturas         Factura[]
  movimientosCc    MovimientoCuentaCorriente[]
  movimientosStock MovimientoStock[]
  stockItems       StockItem[]
  remitos          Remito[]

  @@index([tenantId])
  @@map("clientes")
}

model Transportista {
  id                       String    @id @default(cuid())
  tenantId                 String
  tenant                   Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  nombre                   String
  idFiscal                 String?
  email                    String?
  telefono                 String?
  tipo                     String    @default("externo") // siempre externo
  paut                     String?   // número de PAUT
  permisoInternacional     String?   // número de permiso internacional
  fechaVencimientoPermiso  DateTime? // vencimiento del permiso internacional
  pais                     String?   // código de país (AR, UY, PY, CL, BR)
  domicilio                String?   // domicilio legal del transportista
  condicionIva             Int?      // AFIP: 1=IVA RI, 4=IVA Exento, 5=Consumidor Final, 6=Monotributo
  condicionTributaria      String?   // condición tributaria genérica (para países no AR)
  comisionPct              Float?    // % comisión NyM (si null usa el default de ArcaConfig)
  createdAt                DateTime  @default(now())

  choferes         Chofer[]
  vehiculos        Vehiculo[]
  viajes           Viaje[]  @relation("ViajeTransportistaPrincipal")
  viajesEfectivo   Viaje[]  @relation("ViajeTransportistaEfectivo")
  facturas         Factura[]
  liquidaciones    Liquidacion[]

  @@index([tenantId])
  @@map("transportistas")
}

model Chofer {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  nombre          String
  dni             String?
  cuit            String?   // CUIT del chofer (requerido para PAUT)
  licencia        String?
  licenciaVence   DateTime?
  telefono        String?
  transportistaId String?
  transportista   Transportista? @relation(fields: [transportistaId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())

  viajes              Viaje[]
  cargasCombustible   CargaCombustible[]
  remitos             Remito[]

  @@index([tenantId])
  @@map("choferes")
}

model Vehiculo {
  id                 String    @id @default(cuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  patente            String
  tipo               String    // tractor | semirremolque | camion | utilitario | otro
  marca              String?
  modelo             String?
  anio               Int?
  kmActual           Int       @default(0)
  nroChasis          String?
  poliza             String?
  vencimientoPoliza  DateTime?
  tara               Float?
  precinto           String?
  transportistaId    String?
  transportista      Transportista? @relation(fields: [transportistaId], references: [id], onDelete: SetNull)
  createdAt          DateTime  @default(now())

  vehiculosViaje    ViajeVehiculo[]
  cargasCombustible CargaCombustible[]
  intervenciones    Intervencion[]
  remitos           Remito[]

  @@unique([tenantId, patente])
  @@index([tenantId])
  @@map("vehiculos")
}

model ViajeVehiculo {
  id         String   @id @default(cuid())
  tenantId   String
  viajeId    String
  viaje      Viaje    @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  vehiculoId String
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  orden      Int      @default(0)

  @@unique([viajeId, vehiculoId])
  @@index([tenantId])
  @@index([viajeId])
  @@index([vehiculoId])
  @@map("viajes_vehiculos")
}

model ViajeProducto {
  id         String   @id @default(cuid())
  tenantId   String
  viajeId    String
  viaje      Viaje    @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  orden      Int      @default(0)
  cantidad   Float?
  pesoKg     Float?

  @@unique([viajeId, productoId])
  @@index([tenantId])
  @@index([viajeId])
  @@index([productoId])
  @@map("viajes_productos")
}

model Viaje {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  numero           String
  estado           String    @default("pendiente") // pendiente | en_curso | finalizado_sin_facturar | facturado_sin_cobrar | cobrado | cancelado
  clienteId        String
  cliente          Cliente   @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  transportistaId         String?
  transportista           Transportista? @relation("ViajeTransportistaPrincipal", fields: [transportistaId], references: [id], onDelete: SetNull)
  /** Transportista que efectivamente realiza el flete (puede diferir del contratante). */
  transportistaEfectivoId String?
  transportistaEfectivo   Transportista? @relation("ViajeTransportistaEfectivo", fields: [transportistaEfectivoId], references: [id], onDelete: SetNull)
  choferId         String?
  chofer           Chofer?   @relation(fields: [choferId], references: [id], onDelete: SetNull)
  vehiculosViaje   ViajeVehiculo[]
  origen           String?
  destino          String?
  fechaCarga       DateTime?
  fechaDescarga    DateTime?
  productosViaje   ViajeProducto[]
  detalleCarga     String?
  kmRecorridos     Int?
  litrosConsumidos Float?
  monto            Float?
  monedaMonto      String    @default("ARS") // ARS | USD
  precioTransportistaExterno Float?
  monedaPrecioTransportistaExterno String @default("ARS") // ARS | USD
  /** Solo cuando monedaMonto ≠ monedaPrecioTransportistaExterno (VT-82 / multimoneda). */
  gananciaBrutaManual        Float?
  monedaGananciaBrutaManual  String?  // ARS | USD
  observaciones    String?
  otrosGastos         Json      @default("[]")
  pagosTransportista  Json      @default("[]")
  /** Datos comerciales/aduaneros MIC·CRT (independientes del monto operativo del viaje). */
  documentoAduanero   Json      @default("{}")
  fechaFinalizado  DateTime?
  createdAt        DateTime  @default(now())
  createdBy        String

  facturaId  String?
  factura    Factura? @relation(fields: [facturaId], references: [id], onDelete: SetNull)
  nroFactura String?
  movimientosCuentaCorriente MovimientoCuentaCorriente[]
  liquidacionesViaje         LiquidacionViaje[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, clienteId])
  @@index([tenantId, transportistaId])
  @@index([tenantId, transportistaEfectivoId])
  @@index([tenantId, fechaCarga])
  @@index([tenantId, fechaDescarga])
  @@index([tenantId, fechaFinalizado])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, estado, fechaDescarga])
  @@map("viajes")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: facturación
// ═══════════════════════════════════════════════════════════════════════════

model Factura {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  numero           String
  tipo             String    // cliente | transportista_externo
  clienteId        String?
  cliente          Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  transportistaId  String?
  transportista    Transportista? @relation(fields: [transportistaId], references: [id], onDelete: SetNull)
  viajes           Viaje[]
  importe          Float
  moneda           String    @default("ARS") // ARS | USD
  fechaEmision     DateTime
  fechaVencimiento DateTime?
  estado           String    @default("pendiente") // pendiente | cobrada | vencida
  diferencia       Float?
  // Campos ARCA — nulos para tenants sin módulo liquidaciones-arca
  cbteTipo         Int?      // 1=Factura A, 6=Factura B
  cbteNro          Int?
  ptoVenta         Int?
  cae              String?
  caeFechaVto      DateTime?
  arcaEstado       String?   // pendiente_cae | autorizado | error
  arcaError        String?
  createdAt        DateTime  @default(now())
  pagos            Pago[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([tenantId, clienteId])
  @@index([tenantId, transportistaId])
  @@index([tenantId, estado])
  @@index([tenantId, fechaEmision])
  @@map("facturas")
}

model Pago {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  facturaId String
  factura   Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  importe   Float
  fecha     DateTime
  formaPago String?  // transferencia | cheque | efectivo
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, facturaId])
  @@map("pagos")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: cuenta corriente
// ═══════════════════════════════════════════════════════════════════════════

model MovimientoCuentaCorriente {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  clienteId  String
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  viajeId    String?
  viaje      Viaje?  @relation(fields: [viajeId], references: [id], onDelete: SetNull)
  tipo       String   // cargo | pago
  origen     String   @default("manual") // manual | viaje
  concepto   String
  importe    Float
  fecha      DateTime
  referencia String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, clienteId])
  @@index([tenantId, clienteId, tipo])
  @@index([tenantId, fecha])
  @@index([tenantId, origen])
  @@index([tenantId, viajeId])
  @@unique([tenantId, viajeId])
  @@map("movimientos_cuenta_corriente")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: stock
// ═══════════════════════════════════════════════════════════════════════════

model Producto {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  nombre            String
  /** lower(trim(collapsed spaces)) — unicidad por tenant (case-insensitive). */
  nombreNormalizado String
  descripcion       String?
  unidadMedida      String   // kg | tn | unidades | rollos | pallets | m3 | litros | otro
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  movimientos    MovimientoStock[]
  presentaciones Presentacion[]
  viajesProducto ViajeProducto[]
  stockItems     StockItem[]

  @@unique([tenantId, nombreNormalizado])
  @@index([tenantId])
  @@index([tenantId, activo])
  @@map("productos")
}

model Presentacion {
  id                  String   @id @default(cuid())
  tenantId            String
  productoId          String
  producto            Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  nombre              String   // ej. "Palet de 8 rollos"
  cantidadEquivalente Float
  unidadEquivalente   String   // unidad de la cantidad equivalente
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  movimientos MovimientoStock[]
  stockItems  StockItem[]

  @@index([tenantId])
  @@index([productoId])
  @@map("presentaciones")
}

model MovimientoStock {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  productoId      String
  producto        Producto      @relation(fields: [productoId], references: [id], onDelete: Restrict)
  presentacionId  String?
  presentacion    Presentacion? @relation(fields: [presentacionId], references: [id], onDelete: SetNull)
  clienteId       String
  cliente         Cliente       @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  tipo            String        // ingreso | egreso | division
  cantidad        Float
  /** Número de remito interno generado al egresar (ej. R-2026-00001). Distinto del módulo Remito. */
  numeroRemito    String?
  remitoId        String?
  remito          Remito?       @relation(fields: [remitoId], references: [id], onDelete: SetNull)
  /** URL del remito escaneado (p. ej. Cloudinary) — preparado para carga futura. */
  remitoUrl       String?
  observaciones   String?
  createdBy       String        @default("")
  fecha           DateTime
  createdAt       DateTime      @default(now())

  @@index([tenantId])
  @@index([tenantId, productoId])
  @@index([tenantId, presentacionId])
  @@index([tenantId, clienteId])
  @@index([tenantId, remitoId])
  @@index([tenantId, fecha])
  @@index([tenantId, createdAt(sort: Desc)])
  @@unique([tenantId, numeroRemito])
  @@map("movimientos_stock")
}

/** Contador por año para numeración de remitos de egreso (transaccional). */
model StockRemitoSecuencia {
  id        String @id @default(cuid())
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  year      Int
  lastValue Int    @default(0)

  @@unique([tenantId, year])
  @@map("stock_remito_secuencias")
}

/** Formato del número de remito de egreso por tenant (prefijo y ancho numérico). */
model StockEgresoRemitoConfig {
  tenantId      String   @id
  tenant        Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  remitoPrefix  String   @default("R")
  remitoDigitos Int      @default(5)
  updatedAt     DateTime @updatedAt

  @@map("stock_egreso_remito_configs")
}

model StockItem {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  productoId     String
  producto       Producto     @relation(fields: [productoId], references: [id], onDelete: Restrict)
  presentacionId String
  presentacion   Presentacion @relation(fields: [presentacionId], references: [id], onDelete: Restrict)
  clienteId      String
  cliente        Cliente      @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  cantidad       Float        @default(0)
  updatedAt      DateTime     @updatedAt

  @@unique([productoId, presentacionId, clienteId])
  @@index([tenantId])
  @@index([tenantId, clienteId])
  @@index([tenantId, productoId])
  @@map("stock_items")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: combustible
// ═══════════════════════════════════════════════════════════════════════════

model CargaCombustible {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  vehiculoId String
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  choferId   String?
  chofer     Chofer?  @relation(fields: [choferId], references: [id], onDelete: SetNull)
  estacion   String
  litros     Float
  importe    Float
  km         Int
  formaPago  String?  // transferencia | cheque | efectivo
  fecha      DateTime
  createdAt  DateTime @default(now())
  createdBy  String

  @@index([tenantId])
  @@index([tenantId, vehiculoId])
  @@index([tenantId, choferId])
  @@index([tenantId, fecha])
  @@index([tenantId, createdBy])
  @@map("cargas_combustible")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: mantenimiento (PostgreSQL; checklist diario en Firestore según doc)
// ═══════════════════════════════════════════════════════════════════════════

model Intervencion {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  vehiculoId  String
  vehiculo    Vehiculo @relation(fields: [vehiculoId], references: [id], onDelete: Restrict)
  tipo        String   // service | aceite | filtro | cubiertas | otro
  descripcion String?
  km          Int?
  proximoKm   Int?
  fecha       DateTime
  createdAt   DateTime @default(now())
  createdBy   String

  @@index([tenantId])
  @@index([tenantId, vehiculoId])
  @@index([tenantId, fecha])
  @@map("intervenciones")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: remitos
// ═══════════════════════════════════════════════════════════════════════════

model Remito {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  numero      String
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  choferId    String?
  chofer      Chofer?  @relation(fields: [choferId], references: [id], onDelete: SetNull)
  vehiculoId  String?
  vehiculo    Vehiculo? @relation(fields: [vehiculoId], references: [id], onDelete: SetNull)
  descripcion String
  fecha       DateTime
  firmaUrl    String?
  estado      String   @default("emitido") // emitido | firmado | facturado
  createdAt   DateTime @default(now())
  movimientosStock MovimientoStock[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([tenantId, clienteId])
  @@index([tenantId, estado])
  @@index([tenantId, fecha])
  @@map("remitos")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: importaciones
// ═══════════════════════════════════════════════════════════════════════════

model ImportTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  modulo    String   // viajes | clientes | choferes | vehiculos | stock | etc.
  nombre    String
  config    Json     // TemplateConfig: sheet, headerRow, columns[]
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs     ImportLog[]
  sessions ImportSession[]

  @@unique([tenantId, modulo])
  @@index([tenantId])
  @@map("import_templates")
}

model ImportSession {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  templateId    String
  template      ImportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  nombreArchivo String
  filasValidas  Json           // ValidatedRow[] — listas para insertar
  errores       Json           // RowError[]
  totalFilas    Int
  expiresAt     DateTime
  createdAt     DateTime       @default(now())

  @@index([tenantId])
  @@map("import_sessions")
}

model ImportLog {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  templateId    String?
  template      ImportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  modulo        String
  nombreArchivo String
  estado        String          @default("completado") // completado | con_errores | fallido
  totalFilas    Int
  exitosas      Int             @default(0)
  errores       Int             @default(0)
  detalles      Json            // [{ fila: 2, estado: "ok", id: "..." }, { fila: 3, estado: "error", mensaje: "..." }]
  createdAt     DateTime        @default(now())
  createdBy     String

  @@index([tenantId])
  @@index([tenantId, modulo])
  @@map("import_logs")
}

// ═══════════════════════════════════════════════════════════════════════════
// Módulo: liquidaciones-arca (NyM Logística — CVLP tipo 60 + Facturas A/B vía AFIP SDK)
// ═══════════════════════════════════════════════════════════════════════════

/** Configuración AFIP SDK por tenant. La API key viene de AFIP_SDK_API_KEY (env var). */
model ArcaConfig {
  tenantId              String   @id
  tenant                Tenant   @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  // Datos del emisor para el comprobante PDF
  cuitEmisor            String
  razonSocial           String?  // Razón social del emisor (ej: NyM Logística SRL)
  domicilioEmisor       String?  // Domicilio del emisor
  condicionIvaEmisor    String?  // Condición IVA del emisor (ej: RESP. INSCRIPTO)
  ingBrutos             String?  // N° Ing. Brutos (suele coincidir con CUIT)
  inicActEmisor         String?  // Fecha de inicio de actividades (ej: 01/03/2015)
  // Puntos de venta y ambiente
  ptoVentaCvlp          Int      // punto de venta para CVLP tipo 60
  ptoVentaFactura       Int      // punto de venta para Facturas A/B
  ambiente              String   @default("homologacion") // homologacion | produccion
  // Parámetros de liquidación
  comisionPctDefault    Float    @default(8)
  comisionPctAlt        Float    @default(7)
  ivaGastosAdmin        Float    @default(21)
  updatedAt             DateTime @updatedAt

  @@map("arca_configs")
}

/** Liquidación CVLP tipo 60 — emitida al transportista (fletero). */
model Liquidacion {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  transportistaId String
  transportista   Transportista @relation(fields: [transportistaId], references: [id], onDelete: Restrict)

  // Período de la liquidación
  periodoDesde    DateTime
  periodoHasta    DateTime

  // Montos calculados (snapshot al momento de crear la liquidación)
  cantViajes           Int    // cantidad de viajes incluidos
  bruto                Float  // sum(tnDestino * tarifaTransportista) por todos los viajes
  comisionPct          Float  // % de comisión aplicado
  comision             Float  // bruto * comisionPct / 100
  gastosAdmin          Float  // cantViajes * gastosAdminPorViaje (sin IVA)
  gastosAdminIva       Float  // IVA sobre gastosAdmin
  liquido              Float  // bruto - comision - gastosAdmin - gastosAdminIva (neto al transportista)

  // Campos del comprobante AFIP (cbteTipo siempre 60 para CVLP)
  cbteTipo        Int           @default(60)
  cbteNro         Int?
  ptoVenta        Int?
  cae             String?
  caeFechaVto     DateTime?

  // Estado de la integración ARCA
  estado          String        @default("borrador")
  // borrador | pendiente_cae | autorizado | error | anulado
  arcaError       String?
  reintentos      Int           @default(0)

  // Idempotencia: hash del payload enviado a AFIP SDK (evita duplicar en reintento)
  payloadHash     String?

  createdAt       DateTime      @default(now())
  createdBy       String
  updatedAt       DateTime      @updatedAt

  viajes          LiquidacionViaje[]
  arcaLogs        ArcaLog[]

  @@index([tenantId])
  @@index([tenantId, transportistaId])
  @@index([tenantId, estado])
  @@index([tenantId, periodoDesde, periodoHasta])
  @@map("liquidaciones")
}

/** Viajes incluidos en una liquidación (snapshot de montos al liquidar). */
model LiquidacionViaje {
  id              String      @id @default(cuid())
  tenantId        String
  liquidacionId   String
  liquidacion     Liquidacion @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  viajeId         String
  viaje           Viaje       @relation(fields: [viajeId], references: [id], onDelete: Restrict)

  // Snapshot de los valores al momento de liquidar
  tnOrigen             Float?
  tnDestino            Float?
  tarifaTransportista  Float?  // tarifa por tn aplicada al transportista
  subtotal             Float?  // tnDestino * tarifaTransportista
  gastosAdmin          Float?  // gastos admin tomados del metadata del viaje

  @@unique([liquidacionId, viajeId])
  @@index([tenantId])
  @@index([liquidacionId])
  @@index([viajeId])
  @@map("liquidacion_viajes")
}

/** Log de auditoría de cada request/response a AFIP SDK. */
model ArcaLog {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [clerkOrgId], onDelete: Cascade)
  liquidacionId String?
  liquidacion   Liquidacion? @relation(fields: [liquidacionId], references: [id], onDelete: SetNull)
  // facturaId referencial (sin FK — la Factura puede no tener relación formal con ArcaLog)
  facturaId     String?

  method        String       // afip/auth | FECompUltimoAutorizado | FECAESolicitar
  ambiente      String       // homologacion | produccion
  cuit          String
  requestBody   Json         // payload enviado (sin la API key)
  responseBody  Json?        // respuesta recibida
  httpStatus    Int?
  durationMs    Int?
  exitoso       Boolean      @default(false)
  error         String?

  createdAt     DateTime     @default(now())

  @@index([tenantId])
  @@index([tenantId, liquidacionId])
  @@index([tenantId, facturaId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("arca_logs")
}
