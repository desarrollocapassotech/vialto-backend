  descripcion String
  km Int
  proximoKm Int
  fecha DateTime [not null]
  createdAt DateTime [default: `now()`]
  createdBy String [not null]

  Indexes {
    tenantId
    (tenantId, vehiculoId)
    (tenantId, fecha)
  }
}

