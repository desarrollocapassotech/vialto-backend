{
  "name": "vialto-backend",
  "version": "1.0.0",
  "description": "Backend API para Vialto — SaaS de logística y transporte",
  "main": "dist/main",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "npx @nestjs/cli build",
    "start": "node dist/main",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:prod": "prisma migrate deploy && node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "tenant:ensure": "ts-node scripts/ensure-tenant.ts",
    "migrate:bressan": "ts-node scripts/migrate-bressan-cargas.ts",
    "migrate:bressan:dry": "ts-node scripts/migrate-bressan-cargas.ts --dry-run",
    "fix:combustible": "ts-node scripts/fix-combustible-cargas-sospechosas.ts",
    "fix:combustible:dry": "ts-node scripts/fix-combustible-cargas-sospechosas.ts --dry-run"
  },
  "dependencies": {
    "@clerk/backend": "^1.34.0",
    "@clerk/clerk-sdk-node": "^4.13.23",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^6.5.0",
    "@sentry/node": "^8.55.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.10.0",
    "jsonwebtoken": "^9.0.3",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.9",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "firebase-admin": "^14.1.0",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
