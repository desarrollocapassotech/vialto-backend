# Clerk
CLERK_SECRET_KEY=sk_test_Wo9wmNfxssQUsQa6ZNr3shyAhftuBhWZ0krWQt8shM
CLERK_PUBLISHABLE_KEY=pk_test_b2JsaWdpbmctc3VuZmlzaC05MS5jbGVyay5hY2NvdW50cy5kZXYk

# IDs de usuario Clerk (user_...) separados por coma — superadmin sin depender solo del JWT
# Opcional si ya configurás public_metadata.vialtoRole en el usuario y el backend puede leerla vía API
SUPERADMIN_CLERK_USER_IDS=

# PostgreSQL (Neon.tech)
# URL pooled (PgBouncer) — para queries en runtime
DATABASE_URL=postgresql://USER:PASS@ep-XXXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# URL directa (sin pooler) — solo para migraciones Prisma
# En Neon: Connection Details → Connection string → elegir "Direct connection" (sin "-pooler" en hostname)
DATABASE_URL_UNPOOLED=postgresql://USER:PASS@ep-XXXXX.REGION.aws.neon.tech/neondb?sslmode=require

# Firebase / Firestore (tiempo real — checklist, panel flota)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry (opcional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# App
PORT=8080
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Stripe (futuro)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
