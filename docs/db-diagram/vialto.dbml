// =============================================================================
// MÓDULO: integracion-arca / liquidaciones-arca (implementado — Fase NyM)
// =============================================================================

Table arca_configs as "[IMP-ARCA] arca_configs" {
  tenantId String [pk, ref: > tenants.clerkOrgId]
  cuitEmisor String [not null]
  razonSocial String
  domicilioEmisor String
  condicionIvaEmisor String
  ingBrutos String
  inicActEmisor String
  ptoVentaCvlp Int [not null]
  ptoVentaFactura Int [not null]
  ambiente String [default: 'homologacion']
  comisionPctDefault Float [default: 8]
  comisionPctAlt Float [default: 7]
  ivaGastosAdmin Float [default: 21]
  certPem String [note: 'nunca exponer en API pública']
  keyPem String
  updatedAt DateTime
}

Table liquidaciones as "[IMP-ARCA] liquidaciones" {
  id String [pk]
  tenantId String [not null, ref: > tenants.clerkOrgId]
  transportistaId String [not null, ref: > transportistas.id]
  periodoDesde DateTime [not null]
  periodoHasta DateTime [not null]
  cantViajes Int [not null]
  bruto Float [not null]
  comisionPct Float [not null]
  comision Float [not null]
  gastosAdmin Float [not null]
  gastosAdminIva Float [not null]
  liquido Float [not null]
  cbteTipo Int [default: 60, note: 'CVLP tipo 60']
  cbteNro Int
  ptoVenta Int
  cae String
  caeFechaVto DateTime
  estado String [default: 'borrador']
  arcaError String
  reintentos Int [default: 0]
  comprobanteUrl String [note: 'Cloudinary']
  payloadHash String
  createdAt DateTime [default: `now()`]
  createdBy String [not null]
  updatedAt DateTime

  Indexes {
    tenantId
    (tenantId, transportistaId)
    (tenantId, estado)
    (tenantId, periodoDesde, periodoHasta)
  }
}

Table liquidacion_viajes as "[IMP-ARCA] liquidacion_viajes" {
  id String [pk]
  tenantId String [not null]
  liquidacionId String [not null, ref: > liquidaciones.id]
  viajeId String [not null, ref: > viajes.id]
  tnOrigen Float
  tnDestino Float
  tarifaTransportista Float
  subtotal Float
  gastosAdmin Float

  Indexes {
    (liquidacionId, viajeId) [unique]
    tenantId
    liquidacionId
    viajeId
  }
}

Table arca_logs as "[IMP-ARCA] arca_logs" {
  id String [pk]
  tenantId String [not null, ref: > tenants.clerkOrgId]
  liquidacionId String [ref: > liquidaciones.id]
  facturaId String [note: 'referencial, sin FK formal']
  method String [not null]
  ambiente String [not null]
  cuit String [not null]
  requestBody Json [not null]
  responseBody Json
  httpStatus Int
  durationMs Int
  exitoso Boolean [default: false]
  error String
  createdAt DateTime [default: `now()`]

  Indexes {
    tenantId
    (tenantId, liquidacionId)
    (tenantId, facturaId)
    (tenantId, createdAt)
  }
}

// =============================================================================
// PLANIFICADO — aún no en schema.prisma
// =============================================================================

Table tenant_configs as "[PLAN-C2] tenant_configs" [note: 'PLANIFICADO — Capa 2 feature flags (CLAUDE.md). Módulo: core'] {
  id String [pk]
  tenantId String [unique, not null, ref: > tenants.clerkOrgId]
  flags Json [default: `'{}'`, note: 'ej. { viajes: {...}, liquidaciones: {...} }']
  createdAt DateTime [default: `now()`]
  updatedAt DateTime

  Indexes {
    tenantId
  }
}

Table users_clerk_sync as "[PLAN-CORE] users_clerk_sync" [note: 'PLANIFICADO / opcional — hoy User vive solo en Clerk. Sync local si se necesita reporting offline'] {
  id String [pk, note: 'clerk userId']
  tenantId String [ref: > tenants.clerkOrgId, note: 'org membership activa']
  email String
  firstName String
  lastName String
  role String [note: 'org:admin|org:member|platform']
  lastSyncedAt DateTime
  createdAt DateTime [default: `now()`]

  Indexes {
    tenantId
    email
  }
}

Table viajes_metadata_note as "[PLAN-C3] viajes_metadata" [note: 'PLANIFICADO (conceptual) — si se unifica Capa 3: agregar Viaje.metadata Json. Hoy: documentoAduanero + Json sueltos. No crear tabla real.'] {
  viajeId String [pk, ref: > viajes.id]
  metadata Json [note: 'Fernández MIC/CRT; Riedel despacho; Venturini CTG/granel']
}

Table turnos as "[PLAN-F7] turnos" [note: 'PLANIFICADO — módulo turnos (Fase 7, Pereyra). Aislado. Código módulo: turnos'] {
  id String [pk]
  tenantId String [not null, ref: > tenants.clerkOrgId]
  fecha DateTime [not null]
  estado String [default: 'abierto']
  choferId String [ref: > choferes.id]
  orden Int
  observaciones String
  createdAt DateTime [default: `now()`]

  Indexes {
    (tenantId, fecha)
    tenantId
  }
}

Table reportes_snapshots as "[PLAN-F8] reportes_snapshots" [note: 'PLANIFICADO — Fase 8 reportes. Cross-módulo; puede ser vistas materializadas o snapshots cache'] {
  id String [pk]
  tenantId String [not null, ref: > tenants.clerkOrgId]
  tipo String [not null, note: 'kpi|dashboard|export']
  periodoDesde DateTime
  periodoHasta DateTime
  payload Json [not null]
  createdAt DateTime [default: `now()`]
  createdBy String

  Indexes {
    (tenantId, tipo)
    tenantId
  }
}

Table afip_comprobantes_generales as "[PLAN-AFIP] afip_comprobantes" [note: 'PLANIFICADO — integración AFIP/ARCA general (facturación electrónica más allá de NyM CVLP). Extiende o complementa Factura/ArcaLog'] {
  id String [pk]
  tenantId String [not null, ref: > tenants.clerkOrgId]
  facturaId String [ref: > facturas.id]
  cbteTipo Int [not null]
  cbteNro Int
  ptoVenta Int
  cae String
  caeFechaVto DateTime
  requestBody Json
  responseBody Json
  estado String
  createdAt DateTime [default: `now()`]

  Indexes {
    tenantId
    (tenantId, facturaId)
  }
}
